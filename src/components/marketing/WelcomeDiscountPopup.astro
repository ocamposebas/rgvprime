    border-radius: inherit;
    padding: 1px;
    pointer-events: none;
    background: linear-gradient(
      125deg,
      rgba(255, 255, 255, 0.26),
      rgba(255, 255, 255, 0.02) 30%,
      rgba(220, 38, 38, 0.25) 72%,
      rgba(255, 255, 255, 0.05)
