    grid-template-columns: minmax(320px, 0.92fr) minmax(400px, 1.08fr);
    width: min(100%, 980px);
    min-height: 610px;
    max-height: min(760px, calc(100svh - 34px));
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 32px;
    background: #070505;
    box-shadow:
      0 60px 180px rgba(0, 0, 0, 0.9),
      0 0 0 1px rgba(220, 38, 38, 0.04),
      0 0 120px rgba(185, 28, 28, 0.13);
    transform: translateY(24px) scale(0.975);
    opacity: 0;
    transition:
      transform 400ms cubic-bezier(0.2, 0.85, 0.2, 1),
      opacity 300ms ease;
  }

  .rgv-welcome-popup.is-open .rgv-welcome-popup__panel {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .rgv-welcome-popup__panel::before {
    content: "";
    position: absolute;
    z-index: 5;
