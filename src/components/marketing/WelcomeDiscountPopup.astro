      font-size: 84px;
    }

    .rgv-welcome-popup__discount div span:first-child {
      font-size: 30px;
    }

    .rgv-welcome-popup__discount div span:last-child {
      font-size: 17px;
    }

    .rgv-welcome-popup__offer > p {
      margin-top: 15px;
      font-size: 10px;
    }

    .rgv-welcome-popup__visual-footer {
      display: none;
    }

    .rgv-welcome-popup__content {
      display: block;
      padding: 28px 22px 24px;
    }

    .rgv-welcome-popup__content h2,
    .rgv-welcome-popup__success h2 {
      max-width: 310px;
      font-size: 35px;
    }

    .rgv-welcome-popup__benefits {
      display: none;
    }

    .rgv-welcome-popup__fields {
      margin-top: 22px;
    }

    .rgv-welcome-popup__close {
      top: 15px;
      right: 15px;
      width: 38px;
      height: 38px;
    }
  }

  @media (max-width: 420px) {
    .rgv-welcome-popup__visual {
      min-height: 170px;
    }

    .rgv-welcome-popup__content {
      padding: 24px 18px 20px;
    }

    .rgv-welcome-popup__content
      > .rgv-welcome-popup__form-state
      > p {
      margin-top: 14px;
      line-height: 1.55;
    }

    .rgv-welcome-popup__fields input {
      height: 52px;
    }

    .rgv-welcome-popup__submit {
      min-height: 54px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rgv-welcome-popup,
    .rgv-welcome-popup__panel,
    .rgv-welcome-popup__close,
    .rgv-welcome-popup__submit,
    .rgv-welcome-popup__success-button {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    const popup = document.getElementById("rgv-welcome-popup");

    if (!popup || popup.dataset.initialized === "true") return;

    popup.dataset.initialized = "true";

    const panel = popup.querySelector(".rgv-welcome-popup__panel");
    const form = document.getElementById("rgv-welcome-form");
    const formState = popup.querySelector("[data-welcome-form-state]");
    const successState = popup.querySelector("[data-welcome-success]");
    const emailInput = document.getElementById("rgv-welcome-email");
    const nameInput = document.getElementById("rgv-welcome-name");
    const consentInput = document.getElementById("rgv-welcome-consent");
    const submitButton = document.getElementById("rgv-welcome-submit");
    const submitLabel = popup.querySelector("[data-submit-label]");
    const errorElement = document.getElementById("rgv-welcome-error");
    const closeButtons = popup.querySelectorAll("[data-welcome-close]");
    const finishButton = popup.querySelector("[data-welcome-finish]");

    const DISMISSED_KEY = "rgv_welcome_popup_dismissed_until_v1";
    const SUBSCRIBED_KEY = "rgv_welcome_popup_subscribed_until_v1";
    const DISMISS_DURATION = 7 * 24 * 60 * 60 * 1000;
    const SUBSCRIBED_DURATION = 365 * 24 * 60 * 60 * 1000;

    let isOpen = false;
    let isSubmitting = false;
    let lastFocusedElement = null;
    let previousOverflow = "";
    let openTimer = null;

    function getStoredTime(key) {
      try {
        return Number(window.localStorage.getItem(key) || 0);
      } catch {
        return 0;
      }
    }

    function setStoredTime(key, value) {
      try {
        window.localStorage.setItem(key, String(value));
      } catch {
        // Storage may be unavailable in privacy mode.
      }
    }

    function isSuppressed() {
      const now = Date.now();

      return (
        getStoredTime(DISMISSED_KEY) > now ||
        getStoredTime(SUBSCRIBED_KEY) > now
      );
    }

    function isExcludedPage() {
      return /^\/(checkout|cart|account|admin|api)(\/|$)/i.test(
        window.location.pathname,
      );
    }

    function anotherDialogIsOpen() {
      const dialogs = document.querySelectorAll(
        '[role="dialog"][aria-modal="true"]',
      );

      return Array.from(dialogs).some(function (dialog) {
        if (dialog === panel || popup.contains(dialog)) return false;

        const styles = window.getComputedStyle(dialog);

        return (
          styles.display !== "none" &&
          styles.visibility !== "hidden" &&
          dialog.getBoundingClientRect().width > 0
        );
      });
    }

    function showError(message) {
      if (!errorElement) return;

      errorElement.textContent = message;
      errorElement.hidden = false;
    }

    function clearError() {
      if (!errorElement) return;

      errorElement.textContent = "";
      errorElement.hidden = true;
    }

    function getFocusableElements() {
      return Array.from(
        popup.querySelectorAll(
          'button:not([disabled]), input:not([disabled]), [href], [tabindex]:not([tabindex="-1"])',
        ),
      ).filter(function (element) {
        return !element.closest("[hidden]");
      });
    }

    function openPopup(options) {
      const settings = options || {};
      const force = settings.force === true;

      if (
        isOpen ||
        isSubmitting ||
        isExcludedPage() ||
        (!force && isSuppressed())
      ) {
        return;
      }

      if (!force && anotherDialogIsOpen()) {
        window.setTimeout(function () {
          openPopup(settings);
        }, 1800);

        return;
      }

      lastFocusedElement = document.activeElement;
      previousOverflow = document.documentElement.style.overflow;

      popup.hidden = false;
      popup.setAttribute("aria-hidden", "false");
      document.documentElement.style.overflow = "hidden";

      window.requestAnimationFrame(function () {
        popup.classList.add("is-open");
      });

      isOpen = true;

      window.setTimeout(function () {
        if (emailInput) emailInput.focus();
      }, 360);
    }

    function closePopup(options) {
      const settings = options || {};
      const rememberDismissal = settings.rememberDismissal !== false;

      if (!isOpen || isSubmitting) return;

      if (rememberDismissal) {
        setStoredTime(DISMISSED_KEY, Date.now() + DISMISS_DURATION);
      }

      popup.classList.remove("is-open");
      popup.setAttribute("aria-hidden", "true");
      document.documentElement.style.overflow = previousOverflow;

      isOpen = false;

      window.setTimeout(function () {
        popup.hidden = true;
      }, 280);

      if (
        lastFocusedElement &&
        typeof lastFocusedElement.focus === "function"
      ) {
        lastFocusedElement.focus();
      }
    }

    function setSubmitting(loading) {
      isSubmitting = loading;

      if (!submitButton || !submitLabel) return;

      submitButton.disabled = loading;
      submitLabel.textContent = loading
        ? "Activating access..."
        : "Send my 10% offer";
    }

    function showSuccess() {
      if (formState) formState.hidden = true;
      if (successState) successState.hidden = false;

      setStoredTime(
        SUBSCRIBED_KEY,
        Date.now() + SUBSCRIBED_DURATION,
      );

      setStoredTime(DISMISSED_KEY, 0);

      if (finishButton) {
        window.setTimeout(function () {
          finishButton.focus();
        }, 100);
      }
    }

    function scheduleAutomaticPopup() {
      if (isSuppressed() || isExcludedPage()) return;

      let activated = false;

      const activate = function () {
        if (activated) return;

        activated = true;

        window.removeEventListener("pointerdown", activate);
        window.removeEventListener("keydown", activate);
        window.removeEventListener("scroll", activate);

        openTimer = window.setTimeout(function () {
          openPopup();
        }, 4500);
      };

      window.addEventListener("pointerdown", activate, {
        once: true,
        passive: true,
      });

      window.addEventListener("keydown", activate, {
        once: true,
      });

      window.addEventListener("scroll", activate, {
        once: true,
        passive: true,
      });

      window.setTimeout(activate, 12000);

      document.addEventListener("mouseout", function (event) {
        if (
          event.clientY <= 0 &&
          !event.relatedTarget &&
          !isOpen &&
          !isSuppressed()
        ) {
          if (openTimer) window.clearTimeout(openTimer);

          openPopup();
        }
      });
    }

    closeButtons.forEach(function (button) {
      button.addEventListener("click", function () {
        closePopup({ rememberDismissal: true });
      });
    });

    if (finishButton) {
      finishButton.addEventListener("click", function () {
        closePopup({ rememberDismissal: false });
      });
    }

    popup.addEventListener("keydown", function (event) {
      if (event.key === "Escape") {
        closePopup({ rememberDismissal: true });
        return;
      }

      if (event.key !== "Tab") return;

      const focusableElements = getFocusableElements();

      if (!focusableElements.length) return;

      const firstElement = focusableElements[0];
      const lastElement =
        focusableElements[focusableElements.length - 1];

      if (event.shiftKey && document.activeElement === firstElement) {
        event.preventDefault();
        lastElement.focus();
      } else if (
        !event.shiftKey &&
        document.activeElement === lastElement
      ) {
        event.preventDefault();
        firstElement.focus();
      }
    });

    if (form) {
      form.addEventListener("submit", async function (event) {
        event.preventDefault();

        if (isSubmitting) return;

        clearError();

        const email = emailInput
          ? emailInput.value.trim().toLowerCase()
          : "";

        const firstName = nameInput ? nameInput.value.trim() : "";
        const consent = consentInput ? consentInput.checked : false;
        const companyInput = form.querySelector('[name="company"]');
        const company = companyInput
          ? companyInput.value.trim()
          : "";

        if (!email || !email.includes("@")) {
          showError("Please enter a valid email address.");

          if (emailInput) emailInput.focus();

          return;
        }

        if (!consent) {
          showError(
            "Please confirm that you agree to receive the welcome email.",
          );

          if (consentInput) consentInput.focus();

          return;
        }

        try {
          setSubmitting(true);

          const response = await fetch(
            popup.dataset.endpoint || "/api/omnisend-welcome",
            {
              method: "POST",
              credentials: "same-origin",
              headers: {
                "Content-Type": "application/json",
                Accept: "application/json",
              },
              body: JSON.stringify({
                firstName,
                email,
                consent,
                company,
                source: "welcome-popup-10",
                pagePath:
                  window.location.pathname +
                  window.location.search,
              }),
            },
          );

          const data = await response.json().catch(function () {
            return null;
          });

          if (!response.ok || !data || data.success !== true) {
            throw new Error(
              data && data.message
                ? data.message
                : "We could not activate your offer. Please try again.",
            );
          }

          showSuccess();
        } catch (error) {
          showError(
            error instanceof Error
              ? error.message
              : "Something went wrong. Please try again.",
          );
        } finally {
          setSubmitting(false);
        }
      });
    }

    window.openRGVWelcomePopup = function () {
      openPopup({ force: true });
    };

    window.addEventListener("rgv:open-welcome-popup", function () {
      openPopup({ force: true });
    });

    if (document.readyState === "loading") {
      document.addEventListener(
        "DOMContentLoaded",
        scheduleAutomaticPopup,
        { once: true },
      );
    } else {
      scheduleAutomaticPopup();
    }
  })();
</script>