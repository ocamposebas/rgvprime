<div
  id="rgv-welcome-popup"
  class="rgv-welcome-popup"
  aria-hidden="true"
  hidden
  data-endpoint="/api/omnisend-welcome"
>
  <button
    class="rgv-welcome-popup__backdrop"
    type="button"
    aria-label="Close welcome offer"
    data-welcome-close
  ></button>

  <section
    class="rgv-welcome-popup__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="rgv-welcome-title"
    aria-describedby="rgv-welcome-description"
  >
    <div class="rgv-welcome-popup__glow"></div>

    <button
      class="rgv-welcome-popup__close"
      type="button"
      aria-label="Close welcome offer"
      data-welcome-close
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6 6l12 12M18 6 6 18"></path>
      </svg>
    </button>

    <div class="rgv-welcome-popup__visual">
      <div class="rgv-welcome-popup__visual-grid"></div>
      <div class="rgv-welcome-popup__visual-light"></div>

      <div class="rgv-welcome-popup__brand">
        <img
          src="/logo.webp"
          alt="RGVPRIME"
          width="220"
          height="72"
          loading="eager"
        />
      </div>

      <div class="rgv-welcome-popup__offer">
        <span class="rgv-welcome-popup__eyebrow">
          Private welcome offer
        </span>

        <div class="rgv-welcome-popup__discount">
          <strong>10</strong>

          <div>
            <span>%</span>
            <span>OFF</span>
          </div>
        </div>

        <p>YOUR FIRST ORDER</p>
      </div>

      <div class="rgv-welcome-popup__visual-footer">
        <span></span>
        <p>Member access activated by email</p>
      </div>
    </div>

    <div class="rgv-welcome-popup__content">
      <div class="rgv-welcome-popup__form-state" data-welcome-form-state>
        <span class="rgv-welcome-popup__content-label">
          RGVPRIME MEMBER ACCESS
        </span>

        <h2 id="rgv-welcome-title">
          Unlock your private welcome offer.
        </h2>

        <p id="rgv-welcome-description">
          Join the RGVPRIME list and receive your exclusive 10% welcome
          offer directly in your inbox.
        </p>

        <div class="rgv-welcome-popup__benefits">
          <div>
            <span>01</span>
            <p>10% welcome offer</p>
          </div>

          <div>
            <span>02</span>
            <p>Priority product updates</p>
          </div>

          <div>
            <span>03</span>
            <p>Private launch access</p>
          </div>
        </div>

        <form id="rgv-welcome-form" novalidate>
          <div class="rgv-welcome-popup__fields">
            <label>
              <span>First name</span>

              <input
                id="rgv-welcome-name"
                name="firstName"
                type="text"
                maxlength="80"
                autocomplete="given-name"
                placeholder="Your name"
              />
            </label>

            <label>
              <span>Email address</span>

              <input
                id="rgv-welcome-email"
                name="email"
                type="email"
                maxlength="254"
                autocomplete="email"
                inputmode="email"
                placeholder="you@example.com"
                required
              />
            </label>
          </div>

          <div class="rgv-welcome-popup__honeypot" aria-hidden="true">
            <label>
              Company
              <input
                name="company"
                type="text"
                tabindex="-1"
                autocomplete="off"
              />
            </label>
          </div>

          <label class="rgv-welcome-popup__consent">
            <input
              id="rgv-welcome-consent"
              name="consent"
              type="checkbox"
              checked
              required
            />

            <span>
              I agree to receive marketing emails and understand that I can
              unsubscribe at any time.
            </span>
          </label>

          <button
            id="rgv-welcome-submit"
            class="rgv-welcome-popup__submit"
            type="submit"
          >
            <span data-submit-label>Send my 10% offer</span>

            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"></path>
            </svg>
          </button>

          <div
            id="rgv-welcome-error"
            class="rgv-welcome-popup__message"
            role="alert"
            hidden
          ></div>

          <button
            class="rgv-welcome-popup__decline"
            type="button"
            data-welcome-close
          >
            No thanks, continue without the offer
          </button>
        </form>

        <p class="rgv-welcome-popup__fine-print">
          Your offer will be delivered by email. Restrictions may apply.
        </p>
      </div>

      <div
        class="rgv-welcome-popup__success"
        data-welcome-success
        aria-live="polite"
        hidden
      >
        <div class="rgv-welcome-popup__success-icon">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m5 12 4 4L19 6"></path>
          </svg>
        </div>

        <span>ACCESS CONFIRMED</span>

        <h2>Welcome to RGVPRIME.</h2>

        <p>
          Your 10% welcome offer is being sent to your inbox. Check your
          promotions or spam folder if you do not see it shortly.
        </p>

        <button
          class="rgv-welcome-popup__success-button"
          type="button"
          data-welcome-finish
        >
          Continue exploring
        </button>
      </div>
    </div>
  </section>
</div>

<style>
  .rgv-welcome-popup,
  .rgv-welcome-popup *,
  .rgv-welcome-popup *::before,
  .rgv-welcome-popup *::after {
    box-sizing: border-box;
  }

  .rgv-welcome-popup[hidden] {
    display: none !important;
  }

  .rgv-welcome-popup {
    position: fixed;
    inset: 0;
    z-index: 2147483000;
    display: grid;
    place-items: center;
    padding: clamp(14px, 3vw, 38px);
    font-family: inherit;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 260ms ease,
      visibility 260ms ease;
  }

  .rgv-welcome-popup.is-open {
    opacity: 1;
    visibility: visible;
  }

  .rgv-welcome-popup__backdrop {
    position: absolute;
