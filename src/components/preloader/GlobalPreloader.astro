---
const {
  logoSrc = "/logo.webp",
  brand = "RGVPRIME",
  subtitle = "RESEARCH LLC",
} = Astro.props;
---

<div id="rgv-global-preloader" aria-hidden="true">
  <div class="rgv-preloader-bg"></div>

  <div class="rgv-preloader-content">
    <img
      src={logoSrc}
      alt=""
      class="rgv-preloader-logo"
      draggable="false"
      decoding="async"
      fetchpriority="high"
    />

    <div class="rgv-preloader-copy">
      <h2>{brand}</h2>
      <p>{subtitle}</p>
    </div>

    <div class="rgv-preloader-bar">
      <span></span>
    </div>

    <div class="rgv-preloader-loading">
      <span>Loading</span>
      <span class="rgv-preloader-dots">...</span>
    </div>
  </div>

  <div class="rgv-preloader-bottom-bar"></div>
</div>

<style is:global>
  html.rgv-preloader-lock,
  html.rgv-preloader-lock body {
    overflow: hidden;
  }

  #rgv-global-preloader {
    position: fixed;
    inset: 0;
    z-index: 999999;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #030303;
    color: #ffffff;
    transition:
      opacity 620ms cubic-bezier(.16, 1, .3, 1),
      transform 620ms cubic-bezier(.16, 1, .3, 1),
      visibility 620ms cubic-bezier(.16, 1, .3, 1);
  }

  #rgv-global-preloader.is-leaving {
    pointer-events: none;
    opacity: 0;
    transform: scale(1.012);
    visibility: hidden;
  }

  .rgv-preloader-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 50% 44%, rgba(220, 38, 38, 0.2), transparent 42%),
      linear-gradient(135deg, #030303, #070202 52%, #020202);
  }

  .rgv-preloader-content {
    position: relative;
    z-index: 2;
    display: flex;
    width: 100%;
    max-width: 420px;
    flex-direction: column;
    align-items: center;
    padding: 0 32px;
    text-align: center;
  }

  .rgv-preloader-logo {
    height: 96px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 0 32px rgba(220, 38, 38, 0.28));
    animation: rgvLogoFloat 2.35s ease-in-out infinite;
  }

  .rgv-preloader-copy {
    margin-top: 32px;
  }

  .rgv-preloader-copy h2 {
    margin: 0;
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.86rem;
    font-weight: 900;
    letter-spacing: 0.42em;
    text-transform: uppercase;
  }

  .rgv-preloader-copy p {
    margin: 6px 0 0;
    color: rgba(252, 165, 165, 0.55);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.34em;
    text-transform: uppercase;
  }

  .rgv-preloader-bar {
    margin-top: 36px;
    height: 2px;
    width: min(260px, 100%);
    overflow: hidden;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
  }

  .rgv-preloader-bar span {
    display: block;
    height: 100%;
    width: 100%;
    border-radius: 999px;
    background: rgb(220, 38, 38);
    box-shadow: 0 0 18px rgba(220, 38, 38, 0.65);
    transform-origin: left center;
    animation: rgvPreloaderProgress 950ms cubic-bezier(.16, 1, .3, 1) forwards;
  }

  .rgv-preloader-loading {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    color: rgba(255, 255, 255, 0.35);
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  .rgv-preloader-dots {
    display: inline-block;
    overflow: hidden;
    width: 1.8em;
    animation: rgvDots 1.2s steps(4, end) infinite;
  }

  .rgv-preloader-bottom-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 1px;
    width: 100%;
    background: rgb(220, 38, 38);
    box-shadow: 0 0 18px rgba(220, 38, 38, 0.75);
    transform-origin: left center;
    animation: rgvPreloaderProgress 950ms cubic-bezier(.16, 1, .3, 1) forwards;
  }

  @keyframes rgvLogoFloat {
    0%,
    100% {
      transform: translateY(0) scale(1);
      opacity: 0.92;
    }

    50% {
      transform: translateY(-5px) scale(1.02);
      opacity: 1;
    }
  }

  @keyframes rgvDots {
    from {
      width: 0;
    }

    to {
      width: 1.8em;
    }
  }

  @keyframes rgvPreloaderProgress {
    from {
      transform: scaleX(0.08);
    }

    to {
      transform: scaleX(1);
    }
  }

  @media (max-width: 640px) {
    .rgv-preloader-logo {
      height: 86px;
    }

    .rgv-preloader-copy h2 {
      font-size: 0.76rem;
      letter-spacing: 0.34em;
    }

    .rgv-preloader-copy p {
      font-size: 0.56rem;
      letter-spacing: 0.26em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rgv-preloader-logo,
    .rgv-preloader-dots,
    .rgv-preloader-bar span,
    .rgv-preloader-bottom-bar {
      animation: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const preloader = document.getElementById("rgv-global-preloader");

    if (!preloader) return;

    root.classList.add("rgv-preloader-lock");

    const startedAt = performance.now();
    const minDuration = 700;

    const finish = () => {
      const elapsed = performance.now() - startedAt;
      const delay = Math.max(0, minDuration - elapsed);

      window.setTimeout(() => {
        preloader.classList.add("is-leaving");
        root.classList.remove("rgv-preloader-lock");

        window.setTimeout(() => {
          preloader.remove();
        }, 650);
      }, delay);
    };

    if (document.readyState === "interactive" || document.readyState === "complete") {
      window.setTimeout(finish, 120);
    } else {
      document.addEventListener("DOMContentLoaded", finish, { once: true });
    }
  })();
</script>