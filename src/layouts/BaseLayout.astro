---
import "../styles/global.css";

import Agegate from "../components/agegate/AgeGate";
import GlobalPreloader from "../components/preloader/preloader";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
}

const siteName = "RGVPRIME RESEARCH LLC";
const brandName = "RGVPRIME RESEARCH LLC";
const siteUrl = "https://rgvprimellc.com";

const {
  title = "RGVPRIME RESEARCH LLC | Research Products",
  description = "RGVPRIME RESEARCH LLC provides research-use products through a clean, secure, and modern customer experience.",
  image = "/og-image.jpg",
  noindex = false,
  canonical,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalUrl = canonical || new URL(currentPath, siteUrl).toString();
const ogImageUrl = new URL(image, siteUrl).toString();

const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: brandName,
  url: siteUrl,
  logo: new URL("/logo.webp", siteUrl).toString(),
  sameAs: [],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: brandName,
  url: siteUrl,
};
---

<!doctype html>
<html lang="en">
  <head>
    <!-- BASIC -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- CANONICAL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- INDEXING -->
    {
      noindex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <meta name="robots" content="index, follow" />
      )
    }

    <!-- FAVICONS -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- THEME -->
    <meta name="theme-color" content="#050505" />
    <meta name="color-scheme" content="dark" />

    <!-- OPEN GRAPH -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- TWITTER / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- OPTIONAL LOGO PRELOAD -->
    <link
      rel="preload"
      as="image"
      href="/logo-small.webp"
      imagesrcset="/logo-small.webp 336w, /logo-small@2x.webp 672w"
      imagesizes="336px"
    />

    <!-- JSON-LD SEO -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(organizationSchema)}
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
  </head>

  <body>
    <GlobalPreloader client:load />

    <div class="site-shell">
      <Agegate client:load />
      <slot />
    </div>
  </body>
</html>